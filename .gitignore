# ─────────────────────────────────────────────────────────────────────────────
# Papter — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ══ Environment & Secrets ════════════════════════════════════════════════════
# Never commit real env files — only the .example templates
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
backend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Always keep example/template env files — they are safe to commit
!.env.example
!**/.env.example

# ══ Python ═══════════════════════════════════════════════════════════════════
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Test & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml

# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Jupyter Notebooks
.ipynb_checkpoints/

# ══ Node / Next.js ═══════════════════════════════════════════════════════════
node_modules/
frontend/node_modules/
.npm
.yarn/
.pnp.*

# Next.js build output
frontend/.next/
frontend/out/

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
frontend/next-env.d.ts

# ══ Data & Uploads ═══════════════════════════════════════════════════════════
# Uploaded PDF files (user data — do not commit)
uploads/
backend/uploads/

# SQLite database files (local state — do not commit)
*.db
*.sqlite
*.sqlite3
papter.db

# ChromaDB vector database (large binary data)
chroma_data/
backend/chroma_data/

# ══ Logs ═════════════════════════════════════════════════════════════════════
*.log
logs/
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ══ OS / Editor ══════════════════════════════════════════════════════════════
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# VSCode
.vscode/
*.code-workspace

# JetBrains IDEs (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws

# Vim / Emacs
*.swp
*.swo
*.bak
*~
\#*\#

# ══ AI / ML Model Caches ═════════════════════════════════════════════════════
# Hugging Face model cache (BGE embedding model — downloaded at runtime)
.cache/
backend/.cache/
*.ckpt
*.pt
*.pth
*.safetensors

# Sentence-transformers local cache
sentence_transformers_cache/

# ══ Miscellaneous ════════════════════════════════════════════════════════════
# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak

# Test output / fixtures
test_uploads/
test_data/

# Coverage reports
lcov.info
