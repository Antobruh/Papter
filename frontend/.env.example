# ─────────────────────────────────────────────────────────────────────────────
# Papter — Frontend environment variables
# Copy this file to .env.local and fill in your values.
# Never commit your actual .env.local file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of the Papter FastAPI backend.
# In development this is the local uvicorn server.
# In production, replace with your deployed API URL (e.g. https://api.yourapp.com).
NEXT_PUBLIC_API_URL=http://localhost:8000
