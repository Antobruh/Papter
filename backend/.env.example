# ─────────────────────────────────────────────────────────────────────────────
# Papter — Backend environment variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file.
# For Postgres: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./papter.db

# ── File Storage ──────────────────────────────────────────────────────────────
# Directory where uploaded PDF files are stored.
UPLOAD_DIR=./uploads

# ── Ollama (Local LLM) ────────────────────────────────────────────────────────
# Base URL of the Ollama server. Default is localhost.
OLLAMA_BASE_URL=http://localhost:11434

# The Ollama model to use for AI analysis and chat.
# Recommended: qwen3:8b (pull with: ollama pull qwen3:8b)
# Other options: llama3:8b, mistral:7b, gemma3:12b
DEFAULT_LLM_MODEL=qwen3:8b

# Timeout in seconds for Ollama API calls.
# Increase this if you get timeout errors on slower machines.
OLLAMA_TIMEOUT=120

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Directory for ChromaDB persistent vector storage.
# Leave as default unless you have a reason to change it.
CHROMA_PERSIST_DIR=./chroma_data

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your production domain here when deploying.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
